{
  "name": "chatterbox2",
  "version": "0.0.0",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "npx esbuild src/functions/*.ts --bundle --platform=node --target=node22 --outdir=dist/functions --external:@twilio-labs/serverless-runtime-types",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "test": "jest",
    "prestart": "npm run lint && npm run build",
    "start": "twilio-run --functions-folder dist/functions",
    "predeploy": "npm run lint && npm test && npm run build",
    "deploy": "npx dotenv-cli -- twilio-run deploy --service-name ${SERVICE_NAME:-chatterbox2} --functions-folder dist/functions --runtime node22 --override-existing-project",
    "promote": "twilio-run promote --to= --from=dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@twilio-labs/serverless-runtime-types": "^4.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "twilio-run": "^5.0.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "22"
  }
}
